# ---- Root environment variables for Docker Compose ----
# Copy this file to ".env" (cp .env.example .env) before running
# `docker compose up`. Never commit your real .env file.

# PostgreSQL credentials (used by the db, backend, and compose).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=inventory

# Backend settings.
CORS_ORIGINS=*
LOW_STOCK_THRESHOLD=10
SEED_DATA=true
