# ---- Backend environment variables ----
# Copy to .env for local non-Docker runs. Never commit real credentials.

# SQLAlchemy / PostgreSQL connection string.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/inventory

# Comma-separated allowed frontend origins, or "*" for any origin.
CORS_ORIGINS=*

# Products at or below this stock level are flagged as low stock.
LOW_STOCK_THRESHOLD=10

# Seed demo data on first startup (true/false).
SEED_DATA=true
